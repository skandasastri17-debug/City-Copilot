# City Copilot local environment template
# Copy this file to .env.local if you want server-side local keys.
# Do not commit real API keys.

VULTR_API_KEY=replace-with-your-vultr-key
VULTR_API_BASE_URL=https://your-vultr-openai-compatible-endpoint/v1
VULTR_MODEL=minimax-m2.7

# Optional fallbacks
OPENAI_API_KEY=optional
OPENAI_MODEL=gpt-4.1-mini
AI_API_KEY=optional
AI_BASE_URL=optional
AI_MODEL=optional

# Optional Toronto data token
TORONTO_OPEN_DATA_APP_TOKEN=optional
